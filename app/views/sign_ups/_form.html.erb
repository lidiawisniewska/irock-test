<%= form_with(model: user, url: sign_up_path, data: { controller: "email-validation" }) do |form| %>
  <% if user.errors.any? %>
    <div class="form-errors">
      <% user.errors.each do |error| %>
        <p><%= error.full_message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :email, "Your email", class: "field__label" %>
    <%= form.email_field :email, placeholder: "Email", class: "field__input",
          data: {
            email_validation_target: "email",
            action: "blur->email-validation#validate input->email-validation#validate"
          } %>
    <div class="field__error" data-email-validation-target="message"></div>
  </div>

  <div class="field">
    <%= form.label :name, "Your name", class: "field__label" %>
    <%= form.text_field :name, placeholder: "Name", class: "field__input" %>
  </div>

  <%= form.submit "Join the waiting list", class: "btn", data: { email_validation_target: "submit" } %>
<% end %>
